# MatchMuse - Environment Configuration
# Copy this file to .env and update with your actual values

# =======================================
# OpenAI Configuration
# =======================================
# Get your API key from the OpenAI platform
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use for ranking, translation, and resume updates
OPENAI_MODEL=gpt-4o

# =======================================
# Login Credentials
# =======================================
# Username and password for the MatchMuse login page
MATCHMUSE_USERNAME=your_username_here
MATCHMUSE_PASSWORD=your_secure_password_here

# =======================================
# Streamlit Configuration
# =======================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
