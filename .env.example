# MatchMuse - Environment Configuration
# Copy this file to .env and update with your actual values

# =======================================
# Nexus API Configuration
# =======================================
# Get your API key from the GenAI-Nexus (AWS Bedrock) portal
NEXUS_API_KEY=your_nexus_api_key_here

# Nexus API endpoint (GenAI-Nexus AWS Bedrock)
NEXUS_API_URL=https://genai-nexus.api.corpinter.net/

# =======================================
# Login Credentials
# =======================================
# Username and password for the MatchMuse login page
MATCHMUSE_USERNAME=your_username_here
MATCHMUSE_PASSWORD=your_secure_password_here

# =======================================
# Streamlit Configuration
# =======================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
